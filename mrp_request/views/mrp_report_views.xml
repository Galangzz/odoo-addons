<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- SEARCH  -->
    <record id="mrp_production_reporting_view_search" model="ir.ui.view">
        <field name="name">mrp.production.view.search</field>
        <field name="model">mrp.production</field>
        <field name="arch" type="xml">
            <search string="Search Reporting">
                <field name="product_id" />
                <field name="request_approver_id" />
                <group>
                    <filter name="r_state" string="State"
                        context="{'group_by': 'state'}" />
                    <filter name="group_product_id" string="Product"
                        context="{'group_by': 'product_id'}" />
                </group>
            </search>
        </field>
    </record>


    <!-- ACTION REPORT -->
    <record id="mrp_request_reporting_action" model="ir.actions.act_window">
        <field name="name">Mrp Request Report</field>
        <field name="res_model">mrp.production</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="mrp_production_reporting_view_search" />
        <field name="domain">[]</field>
        <field name="context">{'search_default_group_product_id': True}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">Manufacturing Reporting</p>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="mrp_reporting_view_list" model="ir.ui.view">
        <field name="name">mrp.production.view.list</field>
        <field name="model">mrp.production</field>
        <field name="arch" type="xml">
            <list string="Manufacturing Reporting" default_order="date_start desc" create="0"
                edit="0" delete="0">
                <field name="product_id" string="Product" widget="many2one"
                    options="{'no_open': False}" />
                <field name="request_id" string="Manufacture Request" widget="many2one"
                    options="{'no_open': False}" />
                <field name="name" string="Manufacture Order" />
                <field name="date_start" string="Manufacturin Date" />
                <field name="product_qty" string="Plan Quantity" />
                <field name="qty_producing" string="Produced Quantity" />
                <field name="scrap_count" string="Scrap Quantity" />
                <field name="remaining_qty" string="Remaining Quantity" />
                <field name="efisiensi" string="Efisiensi" />
                <field name="state"
                    decoration-muted="state =='draft'"
                    decoration-info="state == 'progress'"
                    decoration-success="state in ('confirmed', 'done')"
                    decoration-danger="state == 'cancel'"
                    decoration-bf="state == 'done'"
                    decoration-warning="state =='to_close'"
                    widget="badge" class="text-dark"
                />


            </list> 
        </field>
    </record>

    <!-- ACTION VIEW -->
    <record id="action_mrp_request_report" model="ir.actions.act_window.view">
        <field name="sequence" eval="1" />
        <field name="view_mode">list</field>
        <field name="act_window_id" ref="mrp_request_reporting_action" />
        <field name="view_id" ref="mrp_reporting_view_list" />
    </record>

