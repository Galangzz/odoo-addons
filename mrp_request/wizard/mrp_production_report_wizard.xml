<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mrp_production_report_wizard_view_form" model="ir.ui.view">
        <field name="name">mrp.production.report.wizard.view.form</field>
        <field name="model">mrp.production.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Date Pick Report">
                <sheet>
                    <header>
                        <h1>Parameters</h1>
                    </header>
                    <group>
                        <group>

                            <field name="filter_start_date" string="Date Start" />
                            <field name="filter_end_date" string="Date End"/>
                            <field name="format_report" string="Format" widget="radio" />
                        </group>
                    </group>
                </sheet>
                <footer>

                    <button string="Confirm" name="action_print_report" type="object"
                        class="oe_highlight" />
                    <button string="Cancel" special="cancel" type="object" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <record id="mrp_production_report_wizard_action" model="ir.actions.act_window">
        <field name="name">MRP Production Report Wizard</field>
        <field name="res_model">mrp.production.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="target">new</field>
    </record>


    <menuitem
        id="mrp_request_report_reporting_menu"
        name="Production Cycle Report"
        action="mrp_production_report_wizard_action"
        parent="mrp.menu_mrp_reporting"
        sequence="10"/>

</odoo>