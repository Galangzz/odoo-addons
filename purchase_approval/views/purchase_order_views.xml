<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="purchase_order_form_inherit_purchase_approval" model="ir.ui.view">
        <field name="name">purchase.order.view.form.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//form//header//button[@name='button_approve']" position="after">
                <button string="Approve Order" name="button_approve_approver" type="object"
                    class="oe_highlight" groups="purchase_approval.group_purchase_approver"
                    invisible="approve_state != 'approver' or state != 'to approve'" />
                <button string="Approve Order" name="button_approve_director" type="object"
                    class="oe_highlight" groups="purchase_approval.group_purchase_director"
                    invisible="approve_state != 'director' or state != 'to approve'" />
            </xpath>
            <xpath
                expr="//form//sheet//group//field[@name='currency_id'][@groups='base.group_multi_currency']"
                position="after">
                <field name="approve_state" readonly="1"
                    invisible="state != 'to approve' or approve_state == 'approved'"
                    decoration-warning="approve_state != 'approved'" decoration-bf="approve_state != 'approved'"/>
            </xpath>
        </field>
    </record>

</odoo>